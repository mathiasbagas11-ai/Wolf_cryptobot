# ─────────────────────────────────────────────────────────────
# Wolf Crypto Tracker — environment configuration
# Copy to .env and fill in. Variable names match the previous bot
# so an existing Railway / .env config keeps working unchanged.
# ─────────────────────────────────────────────────────────────

# ── Telegram (required for notifications) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional forum-topic routing (leave blank for the main channel)
SIGNAL_THREAD_ID=
NEW_SIGNAL_THREAD_ID=
MARKET_UPDATE_THREAD_ID=
TRADE_REPORT_THREAD_ID=
ALLOWED_CHAT_IDS=

# ── Scheduling (minutes) ──
SCREENER_INTERVAL_MIN=10
TRACKER_INTERVAL_MIN=5

# ── Tracker tuning ──
TRACKER_DEDUP_MINUTES=30
TRACKER_MAX_OUTCOMES=500

# ── Data sources (ordered fallback: first that responds wins) ──
EXCHANGES=binance,okx,bybit

# ── HTTP / storage ──
HTTP_TIMEOUT=10
STATE_DIR=state_data

# ── API server ──
API_HOST=0.0.0.0
API_PORT=8000
# When set, state-mutating endpoints (POST /scan, /track, /signals) require this
# value in the X-API-Key header. Leave empty to keep the API open (local dev).
API_KEY=

# ── Logging ──
LOG_LEVEL=INFO

# ── AI debate layer (Bull vs Bear + arbiter) ──
# Off by default. When enabled, the best candidate per symbol is debated and an
# arbiter may veto low-quality signals.
AI_DEBATE_ENABLED=false
AI_PROVIDER=anthropic
CLAUDE_MODEL=claude-opus-4-8
AI_VETO_ENABLED=true
AI_VETO_MIN_CONFIDENCE=70

# ── Optional integrations (same vars as the previous bot) ──
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
NEWSAPI_KEY=
TWITTER_BEARER_TOKEN=
GLASSNODE_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
