# ─────────────────────────────────────────────────────────────
# Wolf Crypto Tracker — environment configuration
# Copy to .env and fill in. Variable names match the previous bot
# so an existing Railway / .env config keeps working unchanged.
# ─────────────────────────────────────────────────────────────

# ── Telegram (required for notifications) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Per-topic routing (each message type → its own topic; blank → main channel).
# Reuse the SAME thread IDs from the old bot so every topic lights up:
SIGNAL_THREAD_ID=         # ⭐ Signal Entry (activation / TP updates)
NEW_SIGNAL_THREAD_ID=     # ‼️ New Signal (new signal alerts)
HIGH_CONVICTION_THREAD_ID= # 🎯 High-Conviction (TRAP only; blank → New Signal/Trade Reports)
MARKET_UPDATE_THREAD_ID=  # 📚 Market Update (BTC/ETH bias pulse)
TRADE_REPORT_THREAD_ID=   # 📝 Trade Reports (win/loss resolutions)
NEWS_THREAD_ID=           # 🗞 News Update (crypto headlines)
WHALE_THREAD_ID=          # 👁 Whale Report (large trades)
RADAR_THREAD_ID=          # 🔥 Hot Ecosystem (market radar)
MAJORS_THREAD_ID=         # 🐝 BTC/ETH/SOL (majors session report)
FLOW_THREAD_ID=           # 🧠 Flow Intelligence (blank → posts to News topic)
SYSTEM_THREAD_ID=         # startup "online" + diagnostics (blank → General)
STATS_THREAD_ID=          # periodic performance summary
ALLOWED_CHAT_IDS=

# ── Risk gates — align entries with the market & protect equity ──
# Default is "Campur" (hybrid): drawdown is always a HARD pause (protects equity),
# while regime + auto-pause run in MONITOR mode (still emit, but flag + down-score
# so you collect the "what if" record). Flip a gate to a hard block once proven.
REGIME_FILTER_ENABLED=true   # read the market regime and flag against-trend entries
REGIME_SYMBOL=BTCUSDT        # bellwether used to read the regime
REGIME_INTERVAL=1h
REGIME_HARD_BLOCK=false      # true → drop against-regime signals instead of flagging
DRAWDOWN_PAUSE_PCT=15        # HARD: pause ALL new entries once equity is this % below peak
AUTOPAUSE_MIN_TRADES=12      # min graded trades before judging a strategy
AUTOPAUSE_MIN_WIN_RATE=38    # below this win-rate, flag that strategy
AUTOPAUSE_HARD_BLOCK=false   # true → stop emitting the strategy instead of flagging

# ── Universe — which symbols get scanned ──
# Dynamic ranks the whole market by 24h volume (meme coins & other ecosystems
# rotate in as they get liquid); core majors are always included. false = the
# fixed majors list only.
UNIVERSE_DYNAMIC=true
UNIVERSE_TOP_N=30            # how many volume leaders to scan beyond the core majors
UNIVERSE_MIN_QUOTE_VOLUME=10000000  # liquidity floor (USDT 24h quote volume)

# ── Display timezone for timestamps (IANA name). WIB = Asia/Jakarta ──
TIMEZONE=Asia/Jakarta

# ── Crypto news (free, key-less) ── set NEWS_ENABLED=true + NEWS_THREAD_ID
# Auto-pipeline: every NEWS_INTERVAL_MIN it fetches all NEWS_SOURCES, dedups
# across them, ranks by engagement, and posts only genuinely-new items.
NEWS_ENABLED=false
NEWS_PROVIDER=cryptocompare          # legacy single-source (used if NEWS_SOURCES blank)
# Multi-source fan-out (CSV): cryptocompare,reddit,hackernews
NEWS_SOURCES=cryptocompare,reddit,hackernews
NEWS_INTERVAL_MIN=30
NEWS_MAX_ITEMS=3
# Synthesise fresh headlines into one AI brief (needs the narrator's API key).
NEWS_SYNTHESIS_ENABLED=false
NEWS_NARRATOR_PROVIDER=deepseek      # deepseek | groq | gemini | anthropic
NEWS_NARRATOR_MODEL=                 # blank → provider default

# ── Flow Intelligence (Nansen-style thread → News topic) ──
# Free data: CoinGecko (FDV/MC, mcap, volume) + DefiLlama (chain DEX volume,
# stablecoin dry powder). An LLM narrator phrases the brief in the thread style;
# without a key it falls back to a deterministic template. Narrator providers:
# deepseek | groq | gemini | anthropic — set the matching API key below.
FLOW_ENABLED=false
FLOW_INTERVAL_MIN=240
FLOW_MARKETS_LIMIT=60
FLOW_MAX_PICKS=3
FLOW_MAX_SKIPS=4
FLOW_MAX_WATCH=2
FLOW_NARRATOR_PROVIDER=deepseek
FLOW_NARRATOR_MODEL=          # blank → provider default (deepseek-chat)

# ── Market reports (each posts to its own topic; enable + set the topic id) ──
MAJORS_ENABLED=false
MAJORS_INTERVAL_MIN=60
RADAR_ENABLED=false
RADAR_INTERVAL_MIN=30
RADAR_MIN_QUOTE_VOLUME=5000000
MARKET_PULSE_ENABLED=false
MARKET_PULSE_INTERVAL=30
WHALE_ENABLED=false
WHALE_INTERVAL_MIN=5
WHALE_MIN_USD=250000

# ── Scheduling ──
SCREENER_INTERVAL_MIN=10
TRACKER_INTERVAL_MIN=5
# Periodic Telegram performance summary (hours; 0 disables)
STATS_REPORT_HOURS=24

# ── Tracker tuning ──
TRACKER_DEDUP_MINUTES=30
TRACKER_MAX_OUTCOMES=500

# ── Paper trading account (drives Trade Report balance/PnL) ──
# Virtual balance that compounds as signals resolve, risking PAPER_RISK_PCT of
# equity per trade. Not a real exchange balance.
PAPER_START_BALANCE=1000
PAPER_RISK_PCT=1.0

# ── Data sources (ordered fallback: first that responds wins) ──
# Available: binance, okx, bybit, gate. Funding rate is read from binance/okx/
# bybit (in this order); gate is klines/price only.
EXCHANGES=binance,okx,bybit,gate

# ── HTTP / storage ──
HTTP_TIMEOUT=10
STATE_DIR=state_data

# ── API server ──
API_HOST=0.0.0.0
API_PORT=8000
# When set, state-mutating endpoints (POST /scan, /track, /signals) require this
# value in the X-API-Key header. Leave empty to keep the API open (local dev).
API_KEY=

# ── Logging ──
LOG_LEVEL=INFO

# ── AI debate layer (Bull vs Bear + arbiter) ──
# Off by default. When enabled, the best candidate per symbol is debated and an
# arbiter may veto low-quality signals. Each role runs on a cheap OpenAI-compat
# provider (no pricey Claude): DeepSeek = bull, Groq = bear, Hermes = arbiter.
# Supported providers: deepseek, groq, hermes, openrouter, anthropic.
AI_DEBATE_ENABLED=false
DEBATE_BULL_PROVIDER=deepseek
DEBATE_BULL_MODEL=deepseek-chat
DEBATE_BEAR_PROVIDER=groq
DEBATE_BEAR_MODEL=llama-3.3-70b-versatile
DEBATE_ARBITER_PROVIDER=hermes
DEBATE_ARBITER_MODEL=nousresearch/hermes-3-llama-3.1-405b
AI_VETO_ENABLED=true
AI_VETO_MIN_CONFIDENCE=70

# ── Optional integrations (same vars as the previous bot) ──
GEMINI_API_KEY=
GROQ_API_KEY=          # bear debater
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=      # bull debater
HERMES_API_KEY=        # arbiter (OpenRouter key — hosts Nous Hermes)
NEWSAPI_KEY=
TWITTER_BEARER_TOKEN=
GLASSNODE_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
